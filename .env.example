# core
ENV=local
DEBUG=true
# db (db = compose service; use localhost when running the app on the host)
DB_SCHEMA=postgresql
DB_HOST=db
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=tinyrag
# llm (OpenRouter — OpenAI-compatible gateway, https://openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
# rag
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=4
COLLECTION_NAME=tinyrag
MAX_UPLOAD_BYTES=20971520
# cors: comma-separated origins; leave empty for same-origin only
CORS_ORIGINS=
