# core
ENV=local
DEBUG=true
# db (localhost:5401 = host → published port; docker-compose loads docker/.env.container for in-container)
DB_SCHEMA=postgresql
DB_HOST=localhost
DB_PORT=5401
DB_USER=user
DB_PASSWORD=password
DB_NAME=tinyrag
# llm
LLM_PROVIDER=openai
# EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# rag
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=4
COLLECTION_NAME=tinyrag
MAX_UPLOAD_BYTES=20971520
# cors: comma-separated origins; leave empty for same-origin only
CORS_ORIGINS=
